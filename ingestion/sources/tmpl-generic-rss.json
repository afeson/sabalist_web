{
  "id": "tmpl-generic-rss",
  "name": "TEMPLATE — Any RSS/Atom feed (set url + category)",
  "enabled": false,
  "_needs": "url",
  "_howto": "Many sites publish RSS for new listings/posts. Set fetch.url to the feed, pick the right category, set enabled:true. No key needed for public RSS.",
  "format": "rss",
  "fetch": { "type": "http", "url": "https://example.com/listings.rss", "headers": { "User-Agent": "Mozilla/5.0 (compatible; SabalistIngestion/0.1)" } },
  "parseOptions": { "itemTag": "item" },
  "schedule": "0 */6 * * *",
  "ownerUserId": "imported-listings",
  "region": "Global",
  "thresholds": { "autoPublishQuality": 0.65, "autoPublishConfidence": 0.6 },
  "mapping": {
    "externalId": ["guid", "link"],
    "title": { "path": "title", "transform": "trim" },
    "description": { "path": "description", "transform": ["stripHtml", "trim"] },
    "category": { "const": "services" },
    "location": { "path": "location", "default": "" },
    "url": "link",
    "postedAt": { "path": "pubDate", "transform": "isoDate" }
  }
}
