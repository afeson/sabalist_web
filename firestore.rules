rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Listings collection
    // Native iOS/Android uses @react-native-firebase/auth but JS SDK Firestore,
    // so request.auth may be null on native. Validate userId field instead.
    // For delete we check resource.data (existing doc) rather than
    // request.resource.data (which is null on delete).
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null
                    || (request.resource.data.userId is string
                        && request.resource.data.userId.size() > 0);
      allow update: if request.auth != null
                    || (request.resource.data.userId is string
                        && request.resource.data.userId.size() > 0);
      allow delete: if request.auth != null
                    || (resource.data.userId is string
                        && resource.data.userId.size() > 0);
    }

    // Users collection - Allow users to read/write their own data
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Favorites subcollection - users can manage their own favorites
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Settings subcollection - users can manage their own settings (location, preferences)
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Ingestion / admin collections -------------------------------------
    // The ingestion pipeline writes via the firebase-admin SDK (bypasses rules).
    // These rules only govern the admin DASHBOARD's reads + review actions.
    // Keep this allowlist in sync with admin/config.js (adminEmails).
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['afesonabebe@yahoo.com'];
    }

    // Review queue — dashboard reads pending items and approves/rejects them.
    match /listings_staging/{id} {
      allow read, update: if isAdmin();
      allow create, delete: if false; // created by the admin-SDK pipeline only
    }

    // Per-run stats + failures — dashboard reads; writes are admin-SDK only.
    match /ingestion_stats/{id} { allow read: if isAdmin(); allow write: if false; }
    match /import_failures/{id} { allow read: if isAdmin(); allow write: if false; }

    // Source configs (when moved into Firestore for UI CRUD).
    match /ingestion_sources/{id} { allow read, write: if isAdmin(); }

    // Backend-driven marketplace config — public read (logged-out web + first
    // app launch need it); only the admin dashboard may write (the seeder uses
    // the admin SDK, which bypasses rules).
    match /marketplace_config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
