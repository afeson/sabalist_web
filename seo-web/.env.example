# Same PUBLIC Firebase config the Expo web app already ships with.
# The `listings` collection is world-readable, so no service account is needed.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_APP_ID=

# On-demand revalidation webhook (must match the Firestore trigger secret)
REVALIDATE_SECRET=

# Existing Expo SPA origin for /app/* interactive routes (leave blank to disable)
SPA_ORIGIN=

# IndexNow instant-indexing key (Bing/Yandex); also host public/<key>.txt
INDEXNOW_KEY=
