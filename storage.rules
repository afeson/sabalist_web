rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideoFile() {
      return request.resource.contentType.matches('video/.*');
    }

    function isValidImageSize() {
      // Max 10MB per image
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isValidVideoSize() {
      // Max 30MB per video
      return request.resource.size < 30 * 1024 * 1024;
    }

    // Listing media: organized by listingId
    // Allow uploads if file type and size are valid
    // (native iOS auth tokens don't reach JS SDK storage, so auth check is relaxed)
    match /listings/{listingId}/{fileId} {
      allow read: if true;

      allow create: if (isImageFile() && isValidImageSize())
                    || (isVideoFile() && isValidVideoSize());

      allow delete: if request.auth != null;
    }

    // Legacy flat structure (backward compatibility)
    match /listings/{fileId} {
      allow read: if true;
      allow create: if (isImageFile() && isValidImageSize())
                    || (isVideoFile() && isValidVideoSize());
      allow delete: if false;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
